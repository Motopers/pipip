#!/usr/bin/env bash
set -u

VERSION="1.3.4"

APP_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/pipip"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/pipip"
CONFIG="$CONFIG_DIR/pipip.conf"

TIMEOUT_SEC=""
STUN_SERVERS=()
GEOIP_DB="$APP_DIR/GeoLite2-City.mmdb"
GEOIP_LANGUAGE="en"
SEPARATOR="|"
SHOW_IP=0
SHOW_COUNTRY=0
SHOW_REGION=0
SHOW_CITY=0
SHOW_COORDINATES=0
SHOW_EMOJI_FLAG=0
SHOW_TEXT_FLAG=0
HAS_OUTPUT_FIELD=0

usage() {
  cat <<EOF_USAGE
Usage: pipip [options]

Options:
  -i, --ip              Print IP
  -c, --country         Print country
  -r, --region          Print region, state, or province
  -g, --city            Print city
  -p, --coordinates     Print approximate latitude and longitude
  -f, --flag            Print emoji flag
  -t, --text-flag       Print text flag
      --separator VALUE Use VALUE between location and IP (default: |)
      --lang VALUE      Print GeoIP names in VALUE language (default: en)
  -h, --help            Print help
  -v, --version         Print version

Config:
  $CONFIG
EOF_USAGE
}

die() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

connection_error() {
  printf '❌ pipip\n'
  exit 1
}

have() {
  command -v "$1" >/dev/null 2>&1
}

require_gnu_getopt() {
  have getopt || die "GNU getopt not found"

  getopt --test >/dev/null 2>&1
  [ "$?" -eq 4 ] || die "GNU getopt is required"
}

select_output_field() {
  case "$1" in
    ip) SHOW_IP=1 ;;
    country) SHOW_COUNTRY=1 ;;
    region) SHOW_REGION=1 ;;
    city) SHOW_CITY=1 ;;
    coordinates) SHOW_COORDINATES=1 ;;
    flag) SHOW_EMOJI_FLAG=1 ;;
    text-flag) SHOW_TEXT_FLAG=1 ;;
  esac

  HAS_OUTPUT_FIELD=1
}

parse_options() {
  require_gnu_getopt

  local parsed
  parsed="$(getopt \
    --options icrgpfthv \
    --longoptions ip,country,region,city,coordinates,flag,text-flag,separator:,lang:,help,version \
    --name pipip \
    -- "$@")" || exit 2

  eval set -- "$parsed"

  while true; do
    case "$1" in
      -i|--ip) select_output_field ip; shift ;;
      -c|--country) select_output_field country; shift ;;
      -r|--region) select_output_field region; shift ;;
      -g|--city) select_output_field city; shift ;;
      -p|--coordinates) select_output_field coordinates; shift ;;
      -f|--flag) select_output_field flag; shift ;;
      -t|--text-flag) select_output_field text-flag; shift ;;
      --separator)
        SEPARATOR="$2"
        shift 2
        ;;
      --lang)
        [ -n "$2" ] || die "--lang requires a non-empty value"
        GEOIP_LANGUAGE="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      -v|--version)
        printf 'pipip %s\n' "$VERSION"
        exit 0
        ;;
      --)
        shift
        break
        ;;
      *)
        die "option parser error"
        ;;
    esac
  done

  [ "$#" -eq 0 ] || die "unexpected argument: $1"
}

load_config() {
  [ -r "$CONFIG" ] || die "config not found: $CONFIG"

  # shellcheck source=/dev/null
  . "$CONFIG"

  [ -n "$TIMEOUT_SEC" ] || die "TIMEOUT_SEC is missing in config"
  [ "${#STUN_SERVERS[@]}" -gt 0 ] || die "STUN_SERVERS is missing in config"
}

parse_stun_ip() {
  awk '
    tolower($0) ~ /mapped/ {
      if (match($0, /([0-9]{1,3}\.){3}[0-9]{1,3}(:[0-9]+)?/)) {
        ip = substr($0, RSTART, RLENGTH)
        sub(/:[0-9]+$/, "", ip)
        print ip
        exit
      }
    }
  '
}

stun_ip() {
  timeout "$TIMEOUT_SEC" stun "$1" -v 2>&1 | parse_stun_ip
}

emoji_flag() {
  local code="${1^^}"
  local first_ascii second_ascii
  local first_tail second_tail

  [ "$code" = "UK" ] && code="GB"

  [[ "$code" =~ ^[A-Z][A-Z]$ ]] || {
    printf '🌍'
    return
  }

  LC_CTYPE=C printf -v first_ascii '%d' "'${code:0:1}"
  LC_CTYPE=C printf -v second_ascii '%d' "'${code:1:1}"

  printf -v first_tail '\\%03o' "$((166 + first_ascii - 65))"
  printf -v second_tail '\\%03o' "$((166 + second_ascii - 65))"

  printf "\360\237\207${first_tail}\360\237\207${second_tail}"
}

mmdb_get_string() {
  local ip="$1"
  shift

  mmdblookup --file "$GEOIP_DB" --ip "$ip" "$@" 2>/dev/null \
    | awk -F'"' '/<utf8_string>/ { print $2; exit }'
}

mmdb_get_number() {
  local ip="$1"
  shift

  mmdblookup --file "$GEOIP_DB" --ip "$ip" "$@" 2>/dev/null \
    | awk '/<(double|float|u?int[0-9]*|uint[0-9]*)>/ { print $1; exit }'
}

mmdb_get_name() {
  local ip="$1"
  shift

  local value
  value="$(mmdb_get_string "$ip" "$@" names "$GEOIP_LANGUAGE")"

  if [ -z "$value" ] && [ "$GEOIP_LANGUAGE" != "en" ]; then
    value="$(mmdb_get_string "$ip" "$@" names en)"
  fi

  printf '%s' "$value"
}

append_location() {
  local value="$1"
  [ -n "$value" ] || return 0
  LOCATION="${LOCATION:+$LOCATION, }$value"
}

parse_options "$@"

if [ "$HAS_OUTPUT_FIELD" = "0" ]; then
  SHOW_CITY=1
  SHOW_COUNTRY=1
  SHOW_IP=1
fi

load_config

have timeout || die "timeout not found"
have stun || die "stun not found"

IP=""

for server in "${STUN_SERVERS[@]}"; do
  IP="$(stun_ip "$server")"
  [ -n "$IP" ] && break
done

[ -n "$IP" ] || connection_error

COUNTRY_CODE=""
COUNTRY=""
REGION=""
CITY=""
LATITUDE=""
LONGITUDE=""

if [ -r "$GEOIP_DB" ] && have mmdblookup; then
  COUNTRY_CODE="$(mmdb_get_string "$IP" country iso_code)"
  COUNTRY="$(mmdb_get_name "$IP" country)"
  REGION="$(mmdb_get_name "$IP" subdivisions 0)"
  CITY="$(mmdb_get_name "$IP" city)"
  LATITUDE="$(mmdb_get_number "$IP" location latitude)"
  LONGITUDE="$(mmdb_get_number "$IP" location longitude)"
fi

FLAGS=""
LOCATION=""
OUTPUT=""

if [ "$SHOW_EMOJI_FLAG" = "1" ] && [ -n "$COUNTRY_CODE" ]; then
  FLAGS="$(emoji_flag "$COUNTRY_CODE")"
fi

if [ "$SHOW_TEXT_FLAG" = "1" ] && [ -n "$COUNTRY_CODE" ]; then
  FLAGS="${FLAGS:+$FLAGS }${COUNTRY_CODE^^}"
fi

[ "$SHOW_CITY" = "1" ] && append_location "$CITY"
[ "$SHOW_REGION" = "1" ] && append_location "$REGION"
[ "$SHOW_COUNTRY" = "1" ] && append_location "$COUNTRY"

if [ "$SHOW_COORDINATES" = "1" ] && [ -n "$LATITUDE" ] && [ -n "$LONGITUDE" ]; then
  append_location "($LATITUDE, $LONGITUDE)"
fi

[ -n "$FLAGS" ] && OUTPUT="$FLAGS"
[ -n "$LOCATION" ] && OUTPUT="${OUTPUT:+$OUTPUT }$LOCATION"

if [ "$SHOW_IP" = "1" ]; then
  if [ -n "$OUTPUT" ]; then
    if [ -n "$SEPARATOR" ]; then
      OUTPUT="$OUTPUT $SEPARATOR $IP"
    else
      OUTPUT="$OUTPUT $IP"
    fi
  else
    OUTPUT="$IP"
  fi
fi

[ -n "$OUTPUT" ] || die "requested GeoIP data is unavailable in: $GEOIP_DB"

printf '%s\n' "$OUTPUT"
